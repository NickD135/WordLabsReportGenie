# Anthropic — get from console.anthropic.com
# Make sure Zero Data Retention is enabled on this account
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — from your project settings
# Project should be in ap-southeast-2 (Sydney)
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Model to use for polish — leave as default unless you know why you're changing it
ANTHROPIC_MODEL=claude-sonnet-4-5
